PORT=3000
APP_PASSCODE=change-this-passcode
TOKEN_SECRET=change-this-random-secret
TOKEN_TTL_SECONDS=604800

# S3-compatible storage settings (Cloudflare R2 / Backblaze B2)
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-key-id
S3_SECRET_ACCESS_KEY=your-secret
S3_ENDPOINT=https://<account-or-endpoint>
S3_REGION=auto
S3_FORCE_PATH_STYLE=false

# Optional
PUBLIC_ASSET_BASE_URL=
MAX_FILE_SIZE_MB=10
SIGNED_URL_TTL_SECONDS=60
METADATA_BACKEND=file
METADATA_PREFIX=_meta
